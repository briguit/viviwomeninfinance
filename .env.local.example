# ──────────────────────────────────────────────
# Vivi — Environment Variables
# Copy this file to .env.local and fill in values
# ──────────────────────────────────────────────

# Privy (auth + embedded wallets)
# Get your App ID at: https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id-here
NEXT_PUBLIC_PRIVY_CLIENT_ID=your-privy-client-id-here

# Privy server API (required for live Earn/send flows; app falls back to demo mode without these)
PRIVY_APP_ID=your-privy-app-id-here
PRIVY_APP_SECRET=your-privy-app-secret-here
PRIVY_EARN_VAULT_ID=your-privy-earn-vault-id-here

# World ID (Sybil-resistance / 1 scholarship per human)
# Create an app at: https://developer.worldcoin.org
# Action must match the action string in OnboardingScreen and /api/verify
NEXT_PUBLIC_WLD_APP_ID=app_staging_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_WLD_ACTION=verify-human
WLD_ACTION=verify-human
# Note: Create your World ID app at https://developer.worldcoin.org
# Use "device" verification level for staging/hackathon (no Orb required)

# Claude API (real Vivi chat, optional — falls back to mock responses)
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
