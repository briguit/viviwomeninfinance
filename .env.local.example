# ──────────────────────────────────────────────
# Vivi — Environment Variables
# Copy this file to .env.local and fill in values
# ──────────────────────────────────────────────

# Privy (auth + embedded wallets)
# Get your App ID at: https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id-here

# World ID (Sybil-resistance / 1 scholarship per human)
# Create an app at: https://developer.worldcoin.org
# Action must match the action string in OnboardingScreen and /api/verify
NEXT_PUBLIC_WLD_APP_ID=app_staging_xxxxxxxxxxxxxxxxxxxxxxxx
WLD_ACTION=verify-human

# Claude API (real Vivi chat, optional — falls back to mock responses)
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
